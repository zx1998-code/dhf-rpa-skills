{
  "name": "@zx1998/dhf-rpa-installer",
  "version": "1.2.0",
  "description": "DHF Agent RPA 自动化技能包 - 按需安装",
  "private": false,
  "type": "module",
  "scripts": {
    "install": "node cli.js",
    "install:global": "node cli.js --global",
    "install:project": "node cli.js --project",
    "install:skill": "node cli.js",
    "install:interactive": "node scripts/install.js",
    "uninstall": "node scripts/uninstall.js",
    "sync": "node scripts/sync.js",
    "list": "node scripts/list.js",
    "update": "node scripts/update.js",
    "setup": "node scripts/setup.js",
    "prepublishOnly": "node scripts/prepare.js",
    "publish:preview": "npm publish --dry-run",
    "publish:public": "npm publish --access public",
    "version:patch": "npm version patch && git push --follow-tags",
    "version:minor": "npm version minor && git push --follow-tags",
    "version:major": "npm version major && git push --follow-tags"
  },
  "keywords": [
    "dhf",
    "rpa",
    "automation",
    "claude-code",
    "skills",
    "browser",
    "web",
    "workflow"
  ],
  "author": {
    "name": "zx1998",
    "email": "zxtest7985@163.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/dhf-rpa-skills.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/dhf-rpa-skills/issues"
  },
  "homepage": "https://github.com/YOUR_USERNAME/dhf-rpa-skills#readme",
  "dependencies": {
    "inquirer": "^9.2.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.0",
    "cli-table3": "^0.6.3"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "scripts/",
    "skills/",
    "packages/",
    "cli.js",
    "README.md",
    "AI-INSTALL-GUIDE.md",
    "INSTALLER.md",
    "LICENSE",
    "INSTALL.md"
  ]
}
